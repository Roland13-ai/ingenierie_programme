1. Les imports

Syntaxe Signification Exemple
import module Importer tout un module import numpy
import module as alias Importer avec un surnom import numpy as np
from module import chose Importer une partie précise from pathlib import Path
from module import a, b, c Importer plusieurs éléments from circuits import impedance_resistance, impedance_condensateur

