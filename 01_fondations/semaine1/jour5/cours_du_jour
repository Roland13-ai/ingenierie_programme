
import matplotlib.pyplot as plt
import sys
from pathlib import Path

# Ajoute le chemin vers circuits.py
sys.path.insert(0, str(Path(__file__).parent.parent / "jour3"))
from circuits import impedance_resistance, impedance_condensateur, impedance_serie, module_et_phase

# Paramètres
R = 1000
C = 1e-6
frequences = np.logspace(0, 5, 200)  # 200 points de 1 Hz à 100 kHz

# Initialise les listes vides
modules = []
phases = []

# Calcule pour chaque fréquence
for f in frequences:
    z_r = impedance_resistance(R)
    z_c = impedance_condensateur(C, f)
    z_eq = impedance_serie(z_r, z_c)
    mod, ph = module_et_phase(z_eq)
    modules.append(mod)
    phases.append(ph)

# Tracé
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 8))

ax1.semilogx(frequences, modules)
ax1.set_ylabel("Module (Ω)")
ax1.set_title("Réponse en fréquence – Filtre RC passe-bas")
ax1.grid(True)

ax2.semilogx(frequences, phases)
ax2.set_xlabel("Fréquence (Hz)")
ax2.set_ylabel("Phase (°)")
ax2.grid(True)

plt.tight_layout()
plt.savefig("01_fondations/semaine1/jour5/data/reponse_RC.png")
plt.show()

